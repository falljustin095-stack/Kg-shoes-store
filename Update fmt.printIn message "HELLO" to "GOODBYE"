# Kg-shoes-store
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KG Shoes Store</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:#f5f7fb;
color:#222;
}

header{
background:#1f2937;
color:white;
text-align:center;
padding:20px;
}

header h1{
font-size:26px;
}

header p{
opacity:0.8;
}

.container{
padding:15px;
max-width:1200px;
margin:auto;
}

.filters{
display:flex;
gap:10px;
overflow:auto;
margin-bottom:15px;
}

.filters button{
border:none;
padding:8px 14px;
border-radius:20px;
background:#e5e7eb;
cursor:pointer;
}

.filters button.active{
background:#2563eb;
color:white;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
gap:15px;
}

.product{
background:white;
border-radius:12px;
padding:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

.product img{
width:100%;
border-radius:10px;
}

.product h3{
font-size:14px;
margin:5px 0;
}

.price{
color:#2563eb;
font-weight:600;
}

.product button{
margin-top:6px;
width:100%;
border:none;
background:#10b981;
color:white;
padding:7px;
border-radius:8px;
cursor:pointer;
}

.cart-btn{
position:fixed;
bottom:20px;
right:20px;
background:#2563eb;
color:white;
border-radius:50px;
padding:12px 18px;
cursor:pointer;
box-shadow:0 5px 12px rgba(0,0,0,0.2);
}

.cart-count{
background:red;
padding:2px 6px;
border-radius:50%;
font-size:12px;
margin-left:4px;
}

.cart-modal{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.5);
display:none;
align-items:center;
justify-content:center;
}

.cart-box{
background:white;
width:90%;
max-width:420px;
max-height:80vh;
overflow:auto;
border-radius:10px;
padding:15px;
}

.cart-item{
display:flex;
justify-content:space-between;
margin-bottom:10px;
}

.qty-btn{
border:none;
padding:3px 8px;
margin:0 2px;
cursor:pointer;
}

.total{
font-weight:bold;
margin-top:10px;
}

.checkout{
margin-top:10px;
width:100%;
background:#2563eb;
color:white;
border:none;
padding:10px;
border-radius:8px;
cursor:pointer;
}

.whatsapp{
position:fixed;
bottom:90px;
right:20px;
background:#25D366;
color:white;
padding:12px 16px;
border-radius:30px;
text-decoration:none;
font-size:14px;
}

form{
display:none;
margin-top:10px;
}

form input, form textarea{
width:100%;
padding:8px;
margin-bottom:8px;
border:1px solid #ddd;
border-radius:6px;
}

form button{
background:#10b981;
border:none;
color:white;
padding:10px;
border-radius:6px;
width:100%;
cursor:pointer;
}

</style>
</head>

<body>

<header>
<h1>KG Shoes Store</h1>
<p>Shoes delivered to your door</p>
</header>

<div class="container">

<div class="filters">
<button class="active" onclick="filterProducts('all')">All</button>
<button onclick="filterProducts('nike')">Nike</button>
<button onclick="filterProducts('puma')">Puma</button>
<button onclick="filterProducts('campus')">Campus</button>
<button onclick="filterProducts('snitch')">Snitch</button>
</div>

<div class="grid" id="productGrid"></div>

</div>

<div class="cart-btn" onclick="openCart()">
Cart <span class="cart-count" id="cartCount">0</span>
</div>

<a class="whatsapp" href="https://wa.me/917398987354" target="_blank">
Chat on WhatsApp
</a>

<div class="cart-modal" id="cartModal">
<div class="cart-box">

<h3>Your Cart</h3>

<div id="cartItems"></div>

<div class="total" id="cartTotal"></div>

<button class="checkout" onclick="toggleForm()">Place Order</button>

<form action="https://formspree.io/f/xlgpjqnb" method="POST">

<input type="text" name="name" placeholder="Customer Name" required>

<input type="tel" name="phone" placeholder="Phone Number" required>

<textarea name="address" placeholder="Delivery Address" required></textarea>

<textarea name="instructions" placeholder="Special Instructions"></textarea>

<input type="hidden" name="order_details" id="orderDetails">

<button type="submit" onclick="submitOrder()">Submit Order</button>

</form>

</div>
</div>

<script>

const products = [

{name:"Nike Air Max",price:700,category:"nike",img:"https://i.ibb.co/B2K97fw6/NIKE-AIR-MAX-2017.jpg"},
{name:"Nike Runner",price:750,category:"nike",img:"https://i.ibb.co/B2K97fw6/NIKE-AIR-MAX-2017.jpg"},
{name:"Puma Street Pro",price:650,category:"puma",img:"https://i.ibb.co/B2K97fw6/NIKE-AIR-MAX-2017.jpg"},
{name:"Puma Active",price:720,category:"puma",img:"https://i.ibb.co/B2K97fw6/NIKE-AIR-MAX-2017.jpg"},
{name:"Campus Runner",price:550,category:"campus",img:"https://i.ibb.co/B2K97fw6/NIKE-AIR-MAX-2017.jpg"},
{name:"Campus Maxx",price:520,category:"campus",img:"https://i.ibb.co/B2K97fw6/NIKE-AIR-MAX-2017.jpg"},
{name:"Snitch Urban",price:600,category:"snitch",img:"https://i.ibb.co/B2K97fw6/NIKE-AIR-MAX-2017.jpg"},
{name:"Snitch Street",price:640,category:"snitch",img:"https://i.ibb.co/B2K97fw6/NIKE-AIR-MAX-2017.jpg"}

]

let cart = JSON.parse(localStorage.getItem("cart")) || []

function renderProducts(list){
const grid=document.getElementById("productGrid")
grid.innerHTML=""
list.forEach((p,i)=>{
grid.innerHTML+=`
<div class="product">
<img src="${p.img}" alt="${p.name}" loading="lazy">
<h3>${p.name}</h3>
<div class="price">₹${p.price}</div>
<button onclick="addToCart(${i})">Add to Cart</button>
</div>`
})
}

function filterProducts(cat){
if(cat==="all") renderProducts(products)
else renderProducts(products.filter(p=>p.category===cat))
}

function addToCart(i){
let item=cart.find(x=>x.name===products[i].name)
if(item) item.qty++
else cart.push({...products[i],qty:1})
saveCart()
}

function saveCart(){
localStorage.setItem("cart",JSON.stringify(cart))
updateCart()
}

function updateCart(){
document.getElementById("cartCount").innerText=cart.reduce((a,b)=>a+b.qty,0)
}

function openCart(){
const modal=document.getElementById("cartModal")
const items=document.getElementById("cartItems")
const total=document.getElementById("cartTotal")
items.innerHTML=""
let sum=0

cart.forEach((item,i)=>{
sum+=item.price*item.qty
items.innerHTML+=`
<div class="cart-item">
<div>${item.name} x ${item.qty}</div>
<div>
<button class="qty-btn" onclick="changeQty(${i},-1)">-</button>
<button class="qty-btn" onclick="changeQty(${i},1)">+</button>
<button class="qty-btn" onclick="removeItem(${i})">x</button>
</div>
</div>`
})

total.innerText="Total: ₹"+sum
modal.style.display="flex"
}

function changeQty(i,n){
cart[i].qty+=n
if(cart[i].qty<=0) cart.splice(i,1)
saveCart()
openCart()
}

function removeItem(i){
cart.splice(i,1)
saveCart()
openCart()
}

function toggleForm(){
document.querySelector("form").style.display="block"
}

function submitOrder(){
let summary=""
let total=0
cart.forEach(i=>{
summary+=`${i.name} x${i.qty} = ₹${i.price*i.qty}\n`
total+=i.price*i.qty
})
summary+="Total = ₹"+total
document.getElementById("orderDetails").value=summary
localStorage.removeItem("cart")
alert("Order placed! KG Shoes Store will contact you on WhatsApp to confirm.")
}

renderProducts(products)
updateCart()

</script>

</body>
</html>
